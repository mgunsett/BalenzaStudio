rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdminUser() {
      let role = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      return role == "admin" || role == "Propietario";
    }

    // Productos: lectura pública, escritura solo admin
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null && isAdminUser();
    }

    // Usuarios: cada usuario lee/escribe su propio perfil
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    // Órdenes: usuarios leen sus propias, admin lee todas
    match /orders/{orderId} {
      allow create: if true;
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        isAdminUser()
      );
      allow update: if request.auth != null && isAdminUser();
    }
  }
}